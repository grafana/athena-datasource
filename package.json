{
  "name": "grafana-athena-datasource",
  "version": "3.2.0",
  "description": "Use Amazon Athena with Grafana",
  "scripts": {
    "build": "webpack -c ./.config/webpack/webpack.config.ts --env production",
    "dev": "webpack -w -c ./.config/webpack/webpack.config.ts --env development",
    "e2e": "playwright test",
    "lint": "eslint --cache .",
    "lint:fix": "npm run lint -- --fix && prettier --write --list-different .",
    "server": "docker compose up --build",
    "sign": "npx --yes --package=@grafana/sign-plugin@3.2.2 sign-plugin",
    "spellcheck": "cspell -c cspell.config.json \"**/*.{ts,tsx,js,go,md,mdx,yml,yaml,json,scss,css}\"",
    "start": "yarn watch",
    "test": "jest --watch --onlyChanged",
    "test:ci": "jest --passWithNoTests --maxWorkers 4",
    "typecheck": "tsc --noEmit",
    "vulncheck": "go run golang.org/x/vuln/cmd/govulncheck@v1.3.0 ./...",
    "watch": "webpack -w -c ./.config/webpack/webpack.config.ts --env development"
  },
  "author": "Grafana Labs",
  "license": "Apache-2.0",
  "dependencies": {
    "@emotion/css": "11.13.5",
    "@grafana/async-query-data": "0.4.3",
    "@grafana/aws-sdk": "0.11.0",
    "@grafana/data": "12.4.3",
    "@grafana/e2e-selectors": "12.4.5",
    "@grafana/i18n": "12.4.3",
    "@grafana/plugin-ui": "0.13.0",
    "@grafana/runtime": "12.4.3",
    "@grafana/schema": "12.4.3",
    "@grafana/ui": "12.4.3",
    "react": "18.3.1",
    "react-dom": "18.3.1",
    "react-router-dom": "6.30.1",
    "semver": "7.7.3",
    "tslib": "2.8.1"
  },
  "devDependencies": {
    "@babel/core": "^7.28.5",
    "@eslint/eslintrc": "3.3.1",
    "@grafana/eslint-config": "8.2.0",
    "@grafana/plugin-e2e": "3.10.0",
    "@grafana/sign-plugin": "3.3.0",
    "@grafana/tsconfig": "2.0.1",
    "@openfeature/web-sdk": "1.9.0",
    "@playwright/test": "1.61.1",
    "@stylistic/eslint-plugin-ts": "4.4.1",
    "@swc/core": "1.14.0",
    "@swc/helpers": "0.5.17",
    "@swc/jest": "0.2.39",
